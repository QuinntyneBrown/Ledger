@startuml
title UML sequence behaviour — Reset a forgotten password
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle { BorderColor #344054 FontColor #101828 }
skinparam package  { BorderColor #667085 FontColor #101828 BackgroundColor #F9FAFB }
actor "Member" as actor
box "Frontend — Ledger Web App" #E0F2FE
  participant "PasswordPage" as page
  participant "AuthApi" as client
end box
box "Backend — Ledger API application" #D1FADF
  participant "AuthController" as controller
end box
box "Backend — Ledger Application and Domain" #ECFDF3
  participant "RequestPasswordResetCommandHandler" as reqHandler
  participant "ResetPasswordCommandHandler" as resetHandler
  participant "PasswordResetToken" as token
end box
box "Backend — Ledger Infrastructure" #FFF4E5
  database "Ledger Database" as db
  participant "Email provider" as email
end box

== Request a reset ==
actor -> page : Submit the forgot-password email
page -> client : Build typed request
client -> controller : HTTPS POST /api/v1/auth/forgot-password
controller -> controller : Apply rate limit per L2-071
controller -> reqHandler : Send RequestPasswordResetCommand
reqHandler -> db : Look up the account by email
db --> reqHandler : Account or none
opt Account exists
  reqHandler -> token : Issue single-use token (<= 1h); invalidate prior per L2-005
  reqHandler -> db : Save the token in one unit of work
  db --> reqHandler : Commit
  reqHandler -> email : Send the reset link
  email --> reqHandler : Accepted for delivery
end
reqHandler --> controller : Neutral result
controller --> client : 200 OK "If that email exists, we've sent a link" per L2-005
client --> page : Neutral confirmation
page --> actor : Present the neutral confirmation

== Complete the reset ==
actor -> page : Open the reset link and submit a new password
page -> page : Enforce password policy per L2-002
page -> client : Build typed request
client -> controller : HTTPS POST /api/v1/auth/reset-password
controller -> controller : Validate input server-side per L2-068
controller -> resetHandler : Send ResetPasswordCommand
resetHandler -> db : Load the reset token by its hash
db --> resetHandler : Token record or none
alt Token valid and unexpired
  resetHandler -> token : Consume the token per L2-006
  resetHandler -> resetHandler : Hash the new password per L2-002
  resetHandler -> db : Update the hash and revoke all sessions per L2-006
  db --> resetHandler : Commit
  resetHandler -> email : Send the confirmation notification per L2-006
  email --> resetHandler : Accepted for delivery
  resetHandler --> controller : Reset result
  controller --> client : 200 OK
  client --> page : Reset succeeded
  page --> actor : Direct to sign in
else Token expired, used, or invalid
  resetHandler --> controller : Invalid-token result
  controller --> client : 400 ProblemDetails
  client --> page : Reset failed
  page --> actor : Offer to request a new link per L2-006
end
@enduml
