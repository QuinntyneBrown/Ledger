@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Manage profile

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Ext(email, "Email provider", "Sends verification, reset, and notification email via SMTP")

System_Boundary(ledger, "Ledger") {
  Container(web, "Ledger Web App", "Angular 21 SPA", "Member-facing responsive web app")
  Container(api, "Ledger API", "ASP.NET Core, MediatR", "CQRS application and domain logic; hosts the SignalR hub")
  ContainerDb(db, "Ledger Database", "SQL Server", "Members, goals, weigh-ins, milestones")
}

Rel(member, web, "Views and edits profile", "HTTPS")
Rel(web, api, "Calls profile and avatar endpoints", "JSON/HTTPS")
Rel(api, db, "Reads and writes User records", "EF Core")
Rel(api, email, "Sends verification email on email change", "SMTP")
@enduml
