@startuml
title UML sequence behaviour — Refresh an access token
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle { BorderColor #344054 FontColor #101828 }
skinparam package  { BorderColor #667085 FontColor #101828 BackgroundColor #F9FAFB }
actor "Member" as actor
box "Frontend — Ledger Web App" #E0F2FE
  participant "AuthApi" as client
end box
box "Backend — Ledger API application" #D1FADF
  participant "AuthController" as controller
end box
box "Backend — Ledger Application and Domain" #ECFDF3
  participant "RefreshTokenCommandHandler" as handler
  participant "RefreshToken" as entity
end box
box "Backend — Ledger Infrastructure" #FFF4E5
  database "Ledger Database" as db
end box
actor -> client : Continue using the app after the access token expires
client -> controller : HTTPS POST /api/v1/auth/refresh with httpOnly cookie per L2-008
controller -> handler : Send RefreshTokenCommand
handler -> db : Load the refresh token by its hash
db --> handler : Token record or none
handler -> entity : Check active, unexpired, not revoked
entity --> handler : Validity result
alt Refresh token valid
  handler -> entity : Revoke the old token and rotate
  handler -> handler : Issue a new signed JWT per L2-008
  handler -> db : Persist the rotated token in one unit of work
  db --> handler : Commit
  handler --> controller : AuthTokens
  controller --> client : 200 OK; new access token and rotated cookie
  client --> actor : Continue without re-entering credentials
else Refresh token revoked or expired
  handler --> controller : Rejected result
  controller --> client : 401 Unauthorized per L2-008
  client --> actor : Return to the sign-in screen
end
@enduml
