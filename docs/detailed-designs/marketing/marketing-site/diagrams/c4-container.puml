@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Marketing site

Person(visitor, "Visitor", "Prospective member browsing the marketing site")
System_Boundary(ledger, "Ledger") {
  Container(site, "Marketing Site", "Server-rendered web", "Public marketing website, independently deployable per L2-062")
  Container(web, "Ledger Web App", "Angular 21 SPA", "Hosts the auth routes the CTA targets")
}
System_Ext(analytics, "Analytics provider", "Optional, non-essential analytics loaded only after consent per L2-061")

Rel(visitor, site, "Browses the landing and legal pages using", "HTTPS")
Rel(site, web, "Routes the visitor to the app auth routes per L2-062", "HTTPS deep link")
Rel(visitor, web, "Registers or signs in using", "HTTPS")
Rel(site, analytics, "Loads non-essential analytics after consent per L2-061", "HTTPS")
@enduml
