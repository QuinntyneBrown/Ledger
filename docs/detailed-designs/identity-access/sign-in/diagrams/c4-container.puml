@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Sign in

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Boundary(ledger, "Ledger") {
  Container(web, "Ledger Web App", "Angular 21 SPA", "Member-facing responsive web app")
  Container(api, "Ledger API", "ASP.NET Core, MediatR", "CQRS application and domain logic; hosts the SignalR hub")
  ContainerDb(db, "Ledger Database", "SQL Server", "Members, refresh tokens, and audit records")
}

Rel(member, web, "Submits credentials over", "HTTPS")
Rel(web, api, "Calls the sign-in and refresh endpoints", "JSON/HTTPS")
Rel(api, db, "Reads accounts; writes refresh tokens and audit records", "EF Core")
@enduml
