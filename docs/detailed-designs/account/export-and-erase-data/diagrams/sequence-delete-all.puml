@startuml
title UML sequence behaviour — Export and erase data: delete all data
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle {
  BorderColor #344054
  FontColor #101828
}
skinparam package {
  BorderColor #667085
  FontColor #101828
  BackgroundColor #F9FAFB
}
actor "Member" as actor
box "Frontend — Ledger Web App" #E0F2FE
  participant "DataAndPrivacyPage" as page
  participant "AccountApi" as client
end box
box "Backend — Ledger API application" #D1FADF
  participant "AccountController" as controller
end box
box "Backend — Ledger Application and Domain" #ECFDF3
  participant "DeleteAllDataCommandHandler" as handler
  participant "AuditLogger" as audit
end box
box "Backend — Ledger Infrastructure" #FFF4E5
  database "Ledger Database" as db
end box

actor -> page : Open danger-zone delete-all
page -> page : Keep destructive button disabled until DELETE is typed per L2-053
actor -> page : Type DELETE and confirm
page -> client : Build typed request
client -> controller : HTTPS POST /api/v1/account/delete-all
controller -> controller : Authenticate and resolve owner per L2-067
controller -> handler : Send DeleteAllDataCommand
handler -> handler : Verify confirmation equals DELETE per L2-053
alt confirmation matches
  handler -> db : Permanently remove owner entries, goal, milestones, and streaks
  db --> handler : Removed
  handler -> audit : Record delete-all per L2-072
  audit -> db : Write audit record
  db --> audit : Commit
  handler --> controller : Success
  controller --> client : 200 OK
  client --> page : Cleared state
  page --> actor : Return to empty/onboarding state per L2-053
else confirmation missing or mismatched
  handler --> controller : Rejected
  controller --> client : 400 ProblemDetails
  client --> page : Destructive action stays disabled
  page --> actor : No data removed
end
@enduml
