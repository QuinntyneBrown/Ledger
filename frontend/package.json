{
  "name": "ledger-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "scripts": {
    "start": "ng serve ledger-app",
    "start:marketing": "ng serve ledger-marketing --port 4300",
    "build": "ng build ledger-app && ng build ledger-marketing",
