@startuml
!include <C4/C4_Component>
LAYOUT_WITH_LEGEND()
title Components — Set a goal

Person(member, "Member", "Tracks weight toward a goal in Ledger")
Container_Boundary(web, "Ledger Web App") {
  Component(page, "GoalPage", "Angular component", "Presents and edits the goal")
  Component(client, "GoalsApi", "Angular HTTP service", "Typed client in ledger/api")
}
Container_Boundary(api, "Ledger API") {
  Component(ctrl, "GoalsController", "ASP.NET Core controller", "Exposes /api/v1/goals endpoints")
  Component(handler, "SetGoalCommandHandler", "MediatR handler", "Applies a goal change in one unit of work")
  Component(entity, "Goal", "Domain entity", "Holds start/goal weight and target date; enforces edit rules")
  ComponentDb(db, "Ledger Database", "SQL Server", "Persists goals and weigh-ins")
}

Rel(member, page, "Edits a goal using", "HTTPS")
Rel(page, client, "Calls")
Rel(client, ctrl, "Sends request", "JSON/HTTPS")
Rel(ctrl, handler, "Sends SetGoalCommand")
Rel(handler, entity, "Loads and mutates")
Rel(handler, db, "Persists", "EF Core")
@enduml
