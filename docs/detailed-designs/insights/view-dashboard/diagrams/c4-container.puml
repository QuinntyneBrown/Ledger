@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — View the dashboard

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Boundary(ledger, "Ledger") {
  Container(web, "Ledger Web App", "Angular 21 SPA", "Member-facing responsive web app")
  Container(api, "Ledger API", "ASP.NET Core, MediatR", "CQRS application and domain logic; hosts the SignalR hub")
  ContainerDb(db, "Ledger Database", "SQL Server", "Members, goals, weigh-ins, milestones")
}
System_Ext(errors, "Error tracking", "Captures unhandled errors with context and alerts on-call")

Rel(member, web, "Opens the dashboard using", "HTTPS")
Rel(web, api, "Requests the dashboard summary", "JSON/HTTPS")
Rel(api, db, "Reads the owner's goal, weigh-ins, and milestones", "EF Core")
Rel(api, errors, "Reports unhandled failures to per L2-084")
@enduml
