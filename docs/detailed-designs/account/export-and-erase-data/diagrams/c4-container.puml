@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Export and erase data

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Ext(email, "Email provider", "Sends verification, reset, and notification email via SMTP")

System_Boundary(ledger, "Ledger") {
  Container(web, "Ledger Web App", "Angular 21 SPA", "Member-facing responsive web app")
  Container(api, "Ledger API", "ASP.NET Core, MediatR", "CQRS application and domain logic; hosts the SignalR hub")
  ContainerDb(db, "Ledger Database", "SQL Server", "Members, goals, weigh-ins, milestones, audit records")
}

Rel(member, web, "Requests export, delete-all, or account deletion", "HTTPS")
Rel(web, api, "Calls account data endpoints", "JSON/HTTPS")
Rel(api, db, "Reads owner data; writes audit records; erases or anonymizes", "EF Core")
Rel(api, email, "Notifies when export is ready per L2-052", "SMTP")
@enduml
