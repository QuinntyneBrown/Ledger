@startuml
!include <C4/C4_Container>
LAYOUT_WITH_LEGEND()
title Containers — Manage reminders

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Ext(push, "Web Push service", "Delivers browser push reminders")

System_Boundary(ledger, "Ledger") {
  Container(web, "Ledger Web App", "Angular 21 SPA", "Member-facing responsive web app")
  Container(api, "Ledger API", "ASP.NET Core, MediatR", "CQRS application, domain logic, and the reminder scheduler")
  ContainerDb(db, "Ledger Database", "SQL Server", "Members, goals, weigh-ins, milestones")
}

Rel(member, web, "Configures reminder toggle, time, and quiet hours", "HTTPS")
Rel(web, api, "Calls reminder endpoint", "JSON/HTTPS")
Rel(api, db, "Reads and writes reminder settings on Preferences", "EF Core")
Rel(api, push, "Delivers due reminders per L2-049", "Web Push")
Rel(push, member, "Shows reminder notification", "Web Push")
@enduml
