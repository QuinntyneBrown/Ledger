@startuml
title UML sequence behaviour — Change a password while signed in
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 12
skinparam defaultFontName Arial
skinparam ArrowColor #344054
skinparam rectangle { BorderColor #344054 FontColor #101828 }
skinparam package  { BorderColor #667085 FontColor #101828 BackgroundColor #F9FAFB }
actor "Member" as actor
box "Frontend — Ledger Web App" #E0F2FE
  participant "PasswordPage" as page
  participant "AuthApi" as client
end box
box "Backend — Ledger API application" #D1FADF
  participant "AuthController" as controller
end box
box "Backend — Ledger Application and Domain" #ECFDF3
  participant "ChangePasswordCommandHandler" as handler
  participant "User" as entity
end box
box "Backend — Ledger Infrastructure" #FFF4E5
  database "Ledger Database" as db
end box
actor -> page : Enter current and new passwords
page -> page : Enforce password policy per L2-002
page -> client : Build typed request
client -> controller : HTTPS POST /api/v1/auth/change-password with bearer token
controller -> controller : Authenticate and resolve the owner per L2-067
controller -> handler : Send ChangePasswordCommand
handler -> db : Load the authenticated account
db --> handler : Account
handler -> entity : Verify the current password per L2-007
entity --> handler : Match or mismatch
alt Current password incorrect
  handler --> controller : Rejected result; credentials unchanged
  controller --> client : 400 ProblemDetails per L2-007
  client --> page : Change rejected
  page --> actor : Present the current-password error
else Current password correct
  handler -> handler : Hash the new password per L2-002
  handler -> entity : Set the new hash and stamp PasswordUpdatedAt per L2-007
  entity --> handler : Updated account
  handler -> db : Save, revoke other sessions per L2-007, and audit per L2-072
  db --> handler : Commit
  handler --> controller : Change result
  controller --> client : 200 OK
  client --> page : Change succeeded
  page --> actor : Confirm and show the updated timestamp per L2-007
end
@enduml
