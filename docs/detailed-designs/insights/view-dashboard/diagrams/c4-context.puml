@startuml
!include <C4/C4_Context>
LAYOUT_WITH_LEGEND()
title System Context — View the dashboard

Person(member, "Member", "Tracks weight toward a goal in Ledger")
System_Boundary(ledger, "Ledger") {
  System(app, "Ledger", "Responsive weight-tracking web application")
}
System_Ext(errors, "Error tracking", "Captures unhandled errors with context and alerts on-call")

Rel(member, app, "Reads the dashboard summary using", "HTTPS")
Rel(app, errors, "Reports unhandled failures to per L2-084")
@enduml
